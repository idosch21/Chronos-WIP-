{
  "manifest_version": 3,
  "name": "Chronos: Productivity Tracker",
  "version": "1.0",
  "permissions": ["tabs", "idle", "storage"],
  "host_permissions": [
    "http://127.0.0.1:8000/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src http://127.0.0.1:8000"
  }
}